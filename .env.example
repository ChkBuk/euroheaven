# Site
NEXT_PUBLIC_SITE_URL=https://euroheaven.com.au

# Hero video CDN URL (Cloudinary / Mux / Bunny). Falls back to /videos/hero.mp4
# if unset, so dev keeps working without configuring a CDN.
NEXT_PUBLIC_HERO_VIDEO_URL=

# Supabase (create a project at https://supabase.com — region: Sydney)
# Both anon + service-role keys live in Project Settings → API.
# When all three are unset, the site falls back to an in-memory store and
# disables magic-link auth + admin gating. Once set, /admin requires the
# user's email to be present in the staff_emails table (or DEV_STAFF_EMAILS).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated dev shortcut to whitelist staff without populating the
# staff_emails table. Example: DEV_STAFF_EMAILS=owner@euroheaven.com.au
DEV_STAFF_EMAILS=

# Google Calendar API (service account with domain-wide delegation, or OAuth)
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_KEY=

# Resend (transactional email) — https://resend.com
# Sender domain (RESEND_FROM_EMAIL) must be DNS-verified in your Resend
# dashboard before live emails will deliver. RESEND_TO_EMAIL is the single
# inbox where booking, contact, and newsletter notifications are delivered.
RESEND_API_KEY=
RESEND_FROM_EMAIL=bookings@euroheaven.com.au
RESEND_TO_EMAIL=info@euroheaven.com.au

# Twilio (SMS) — https://twilio.com
# When all three are set, customers receive SMS confirmations + stage updates,
# AND (if STAFF_NOTIFICATION_PHONE is set) the workshop owner gets an SMS
# alert every time a new booking comes in. Without these, SMS is skipped
# silently — bookings still persist and emails still fire.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Owner mobile to receive "new booking" SMS alerts. Use E.164 format
# (e.g. +61400115765) or AU local (e.g. 0400115765 — auto-normalised).
# Independent of TWILIO_FROM_NUMBER — that's the sender; this is the
# receiver for staff-side notifications.
STAFF_NOTIFICATION_PHONE=

# Set to "true" while running on a Twilio trial account. Switches all
# outbound SMS to a minimal transactional body (no URLs, no marketing
# words, short single segment) to maximise the chance of slipping past
# AU carrier filters that block messages containing the auto-prepended
# "Sent from your Twilio trial account - " preamble. Once you upgrade
# Twilio to a paid account, remove this var or set to "false" to restore
# the richer message (includes /track link, customer details, etc.).
TWILIO_TRIAL_MODE=

# Optional: Google Maps / GA4
NEXT_PUBLIC_GA_ID=

# Upstash Redis — backs the rate limiter on POST routes (booking, contact,
# newsletter, magic-link, chat). Without these, the limiter is a no-op so
# dev keeps working. Free tier: 10K commands/day at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (error monitoring) — optional. Without DSN, the SDK is loaded but
# transmits nothing. Free tier: 5K errors/month at https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Gemini (Google AI Studio) — powers the on-site AI Assistant chatbot.
# Get a free API key at https://aistudio.google.com/apikey — the free tier
# (Gemini 2.0 Flash) includes 1,500 requests/day which is plenty for a
# marketing site. If unset, the chatbot silently falls back to the
# built-in keyword matcher.
GEMINI_API_KEY=
